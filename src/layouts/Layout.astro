---
import '../index.css';
import { config } from '../lib/config';

interface Props {
  title: string;
  description?: string;
}

const { title, description = config.siteDescription } = Astro.props;
const currentYear = new Date().getFullYear();

const siteUrl = config.siteUrl || (config.domain ? `https://${config.domain}` : Astro.site?.href) || 'http://localhost:4321';
const pluginsHead = config._plugins?.head?.replace(/SITE_URL/g, siteUrl) || '';
const pluginsBody = config._plugins?.body?.replace(/SITE_URL/g, siteUrl) || '';
const primary = config.primaryColor || '#7c3aed';
const navItems = config.navigation || [
  { label: 'Início', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: 'Categorias', href: '/categorias' },
  { label: 'Sobre Nós', href: '/sobre' },
  { label: 'Contato', href: '/contato' },
];
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | {config.siteName}</title>
    <meta name="description" content={description} />
    {config.favicon ? (
      <link rel="icon" href={config.favicon} />
    ) : (
      <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 rx=%2220%22 fill=%22%237c3aed%22/><path d=%22M20 35h60v12H20zm0 25h12v10H20zm20 0h30v10H40z%22 fill=%22%23ffffff%22/></svg>" />
    )}
    {pluginsHead && <Fragment set:html={pluginsHead} />}
  </head>
  <body class="bg-slate-50 text-slate-800 font-sans min-h-screen flex flex-col antialiased">
    
    <!-- Top Alert Bar -->
    <div class="bg-purple-700 text-purple-100 py-2 px-4 text-center text-xs font-semibold tracking-wide flex items-center justify-center gap-2">
      <span class="inline-flex h-2 w-2 animate-ping rounded-full bg-purple-300 opacity-75"></span>
      <span>🔥 OFERTAS IMPERDÍVEIS: Cartões com Anuidade Zero e Cashback em Dobro neste mês!</span>
    </div>

    <!-- Main Header -->
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-purple-100 shadow-sm transition-all">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20">
          
          <!-- Logo -->
          <a href="/" class="flex items-center gap-3 group">
            {config.logoUrl ? (
              <img src={config.logoUrl} alt={config.siteName} class="h-10 max-w-[160px] object-contain" />
            ) : (
              <div class="bg-purple-600 text-white p-2.5 rounded-xl shadow-md shadow-purple-200 group-hover:bg-purple-700 transition-all flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                  <rect width="20" height="14" x="2" y="5" rx="2"/>
                  <line x1="2" x2="22" y1="10" y2="10"/>
                  <line x1="6" x2="10" y1="15" y2="15"/>
                </svg>
              </div>
            )}
            <div>
              <span class="font-display font-bold text-xl tracking-tight text-slate-900 group-hover:text-purple-700 transition-colors">{config.siteName}</span>
              <p class="text-[10px] text-slate-500 font-medium tracking-wider uppercase">Comparação Inteligente</p>
            </div>
          </a>

          <!-- Desktop Navigation -->
          <nav class="hidden md:flex items-center gap-8">
            {navItems.map(item => (
              <a href={item.href} class="text-sm font-medium text-slate-600 hover:text-purple-600 transition-colors">{item.label}</a>
            ))}
          </nav>

          <!-- CTA Button -->
          <div class="hidden md:flex items-center">
            <a href="/categorias" class="inline-flex items-center justify-center px-5 py-2.5 rounded-full text-sm font-semibold text-white transition-all shadow-md hover:shadow-lg hover:shadow-purple-200" style={`background-color: ${primary}`}>
              Comparar Cartões
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-1.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>

          <!-- Mobile Menu Button -->
          <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg text-slate-600 hover:text-purple-600 hover:bg-slate-50 transition-all focus:outline-none" aria-label="Toggle Menu">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-7 6h7" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Menu -->
      <div id="mobile-menu" class="hidden md:hidden px-4 pb-4 space-y-1">
        {navItems.map(item => (
          <a href={item.href} class="block w-full text-left px-4 py-3 rounded-xl text-base font-semibold text-slate-700 hover:text-purple-700 hover:bg-purple-50 transition-colors">{item.label}</a>
        ))}
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-slate-900 text-slate-300 mt-16 border-t border-slate-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
          <div>
            <h3 class="font-display text-lg font-bold text-white mb-4">{config.siteName}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">{config.siteDescription}</p>
          </div>
          <div>
            <h4 class="font-semibold text-xs text-white uppercase tracking-widest mb-4 opacity-80">Navegação</h4>
            <div data-no-edit class="space-y-2">
              {navItems.map(item => (
                <a href={item.href} class="block text-sm text-slate-400 hover:text-white transition-colors">{item.label}</a>
              ))}
            </div>
          </div>
          <div>
            <h4 class="font-semibold text-xs text-white uppercase tracking-widest mb-4 opacity-80">Legal</h4>
            <div data-no-edit class="space-y-2">
              <a href="/politica-de-privacidade" class="block text-sm text-slate-400 hover:text-white transition-colors">Política de Privacidade</a>
              <a href="/termos-de-uso" class="block text-sm text-slate-400 hover:text-white transition-colors">Termos de Uso</a>
            </div>
          </div>
          <div>
            <h4 class="font-semibold text-xs text-white uppercase tracking-widest mb-4 opacity-80">Newsletter</h4>
            <form class="flex gap-2" id="newsletter-form" onsubmit="event.preventDefault(); var e=document.getElementById('newsletter-email').value; if(e)fetch(window.location.origin+'/api/leads',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:e,page:'newsletter'})}).then(r=>{document.getElementById('newsletter-msg').style.display='block';document.getElementById('newsletter-msg').textContent='Inscricao realizada!'})">
              <input id="newsletter-email" type="email" placeholder="Seu melhor e-mail" class="flex-1 px-3 py-2.5 rounded-xl bg-slate-800 border border-slate-700 text-sm text-slate-200 placeholder-slate-500 focus:outline-none focus:border-purple-500"/>
              <button type="submit" class="px-4 py-2.5 rounded-xl text-sm font-bold text-white transition-all" style={`background-color: ${primary}`}>OK</button>
            </form>
            <p id="newsletter-msg" style="display:none;font-size:.75rem;color:#a5b4fc;margin-top:.5rem"></p>
          </div>
        </div>
        <div class="mt-12 pt-8 border-t border-slate-800 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-slate-500">
          <p>&copy; {currentYear} {config.siteName}. Todos os direitos reservados. Este site contém links de afiliado.</p>
        </div>
      </div>
    </footer>

    {pluginsBody && <Fragment set:html={pluginsBody} />}

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    </script>
  </body>
</html>
