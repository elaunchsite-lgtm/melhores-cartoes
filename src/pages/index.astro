---
import Layout from '../layouts/Layout.astro';
import CreditCard from '../components/CreditCard.astro';
import { posts } from '../data/posts';

// The first post is the featured one
const featuredPost = posts[0];
const recentPosts = posts.slice(1);
---

<Layout title="Análises dos Melhores Cartões de Crédito de 2026">
  
  <!-- Hero / Introduction -->
  <section class="py-12 sm:py-16 text-center bg-gradient-to-b from-purple-50/50 via-transparent to-transparent">
    <div class="max-w-4xl mx-auto px-4">
      <div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-purple-50 text-purple-700 text-xs font-bold uppercase tracking-wider mb-4 border border-purple-100 animate-pulse">
        <span>⚡</span> RECOMENDAÇÃO EDITORIAL
      </div>
      <h1 class="font-display font-extrabold text-4xl sm:text-5xl md:text-6xl text-slate-900 tracking-tight leading-tight">
        Melhores reviews de <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-indigo-600">cartões de crédito</span> para você
      </h1>
      <p class="mt-4 text-base sm:text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed">
        Análises detalhadas, comparações honestas e as melhores ofertas de cartões de crédito do mercado em 2026 para te ajudar a economizar e maximizar seus pontos.
      </p>
    </div>
  </section>

  <!-- Featured Analysis Card (Layout mimicking reference image, styled in purple) -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
    <div class="bg-white rounded-3xl border border-purple-100 shadow-xl shadow-purple-900/5 overflow-hidden p-6 sm:p-8 lg:p-10 flex flex-col lg:flex-row gap-8 lg:gap-12 items-center hover:border-purple-200 transition-all">
      
      <!-- Left side: Credit Card visual wrapper -->
      <div class="w-full lg:w-1/2 flex justify-center py-6 sm:py-10 bg-slate-50 rounded-2xl border border-slate-100 relative group overflow-hidden">
        <div class="absolute inset-0 bg-radial-gradient from-purple-200/20 to-transparent group-hover:scale-110 transition-transform duration-500"></div>
        <div class="z-10 scale-105 sm:scale-110 drop-shadow-2xl">
          <CreditCard 
            color={featuredPost.cardColor} 
            brand={featuredPost.cardBrand} 
            level={featuredPost.cardLevel} 
            score={featuredPost.score} 
            category={featuredPost.category} 
            size="lg"
          />
        </div>
      </div>

      <!-- Right side: Featured Post Meta and Details -->
      <div class="w-full lg:w-1/2 flex flex-col justify-between h-full space-y-4">
        
        <!-- Category, Score, Date and Readtime -->
        <div class="flex flex-wrap items-center gap-3 text-xs font-semibold">
          <span class="px-3 py-1 rounded-md bg-purple-50 text-purple-700 uppercase tracking-wider">
            {featuredPost.category}
          </span>
          <span class="text-slate-400">•</span>
          <span class="text-slate-500">{featuredPost.readTime}</span>
          <span class="text-slate-400">•</span>
          <span class="text-slate-500">{featuredPost.date}</span>
        </div>

        <!-- Headline -->
        <a href={`/blog/${featuredPost.slug}`} class="group">
          <h2 class="font-display font-extrabold text-2xl sm:text-3xl text-slate-900 group-hover:text-purple-600 transition-colors tracking-tight leading-snug">
            {featuredPost.title}
          </h2>
        </a>

        <!-- Description -->
        <p class="text-slate-600 text-sm sm:text-base leading-relaxed">
          {featuredPost.shortDescription}
        </p>

        <!-- Pros bullet list highlighting key factors -->
        <div class="py-2">
          <span class="text-xs font-bold uppercase tracking-wider text-slate-400">Principais Destaques:</span>
          <ul class="mt-2 space-y-1.5 text-xs text-slate-600">
            {featuredPost.pros.slice(0, 3).map(pro => (
              <li class="flex items-center gap-2">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>{pro}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Author line & Call to Action button -->
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 pt-4 border-t border-slate-100">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-purple-100 text-purple-700 font-bold text-sm flex items-center justify-center border border-purple-200">
              {featuredPost.author.split(' ').map(n => n[0]).join('')}
            </div>
            <div>
              <p class="text-sm font-bold text-slate-900">{featuredPost.author}</p>
              <p class="text-[10px] text-slate-500">{featuredPost.authorRole}</p>
            </div>
          </div>

          <a href={`/blog/${featuredPost.slug}`} class="inline-flex items-center justify-center px-6 py-3.5 rounded-xl font-bold text-sm bg-purple-600 hover:bg-purple-700 text-white transition-all shadow-md hover:shadow-lg shadow-purple-600/10">
            Ler Artigo Completo
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- Recent Analyses Grid (Matching reference's "Últimas Análises" and purple theme) -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
    
    <!-- Title Area -->
    <div class="flex justify-between items-center mb-8 pb-4 border-b border-purple-50">
      <div class="flex items-center gap-3">
        <span class="text-2xl">📝</span>
        <h2 class="font-display font-extrabold text-2xl text-slate-900 tracking-tight">Últimas Análises</h2>
      </div>
      <a href="/blog" class="text-sm font-bold text-purple-600 hover:text-purple-700 transition-colors flex items-center gap-1">
        Ver todos
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>

    <!-- Posts Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {recentPosts.map(post => (
        <article class="bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-lg hover:border-purple-100 transition-all overflow-hidden flex flex-col justify-between group">
          
          <!-- Card Graphic Container -->
          <div class="py-8 bg-slate-50 flex justify-center items-center relative overflow-hidden border-b border-slate-100">
            <div class="scale-95 drop-shadow-lg group-hover:scale-100 transition-transform duration-300">
              <CreditCard 
                color={post.cardColor} 
                brand={post.cardBrand} 
                level={post.cardLevel} 
                score={post.score} 
                category={post.category} 
                size="md"
              />
            </div>
          </div>

          <!-- Content Info -->
          <div class="p-6 flex-grow flex flex-col justify-between">
            <div class="space-y-3">
              <!-- Meta Row -->
              <div class="flex items-center gap-2 text-[11px] font-semibold">
                <span class="text-purple-600 uppercase tracking-wider bg-purple-50 px-2 py-0.5 rounded">
                  {post.category}
                </span>
                <span class="text-slate-300">•</span>
                <span class="text-slate-500">{post.readTime}</span>
              </div>

              <!-- Title -->
              <a href={`/blog/${post.slug}`}>
                <h3 class="font-display font-extrabold text-lg text-slate-900 group-hover:text-purple-600 transition-colors line-clamp-2 leading-snug">
                  {post.title}
                </h3>
              </a>

              <!-- Text summary -->
              <p class="text-slate-600 text-xs sm:text-sm line-clamp-3 leading-relaxed">
                {post.shortDescription}
              </p>
            </div>

            <!-- Footer: Author & Action arrow link -->
            <div class="flex items-center justify-between pt-5 mt-5 border-t border-slate-50">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-purple-50 text-purple-700 font-bold text-xs flex items-center justify-center border border-purple-100">
                  {post.author.split(' ').map(n => n[0]).join('')}
                </div>
                <div>
                  <p class="text-xs font-bold text-slate-900">{post.author}</p>
                  <p class="text-[9px] text-slate-400">{post.date}</p>
                </div>
              </div>

              <a href={`/blog/${post.slug}`} class="w-8 h-8 rounded-full bg-purple-50 text-purple-600 flex items-center justify-center group-hover:bg-purple-600 group-hover:text-white transition-all shadow-sm" aria-label={`Read article about ${post.title}`}>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 stroke-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>

          </div>

        </article>
      ))}
    </div>

  </section>

  <!-- Comparison & Choice helper block -->
  <section class="bg-purple-900 text-purple-100 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center space-y-6">
        <h2 class="font-display font-bold text-3xl sm:text-4xl tracking-tight text-white">Como escolher o cartão ideal?</h2>
        <p class="text-purple-200 leading-relaxed text-sm sm:text-base">
          Nosso objetivo é desmistificar o mercado financeiro. Com ferramentas de comparação isentas, te ajudamos a escolher se o foco ideal para seu padrão de gastos é acumular cashback líquido direto na conta corrente ou juntar milhas aéreas para sua próxima viagem internacional.
        </p>
        <div class="pt-4 flex flex-wrap justify-center gap-4">
          <a href="/categorias" class="px-6 py-3.5 rounded-xl bg-white text-purple-900 hover:bg-purple-50 transition-all font-bold text-sm shadow-md">
            Comparar por Categorias
          </a>
          <a href="/sobre" class="px-6 py-3.5 rounded-xl bg-purple-800 hover:bg-purple-700 text-white transition-all font-bold text-sm border border-purple-700">
            Conhecer Nossos Especialistas
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
