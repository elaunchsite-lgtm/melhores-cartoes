---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Fale Conosco - Melhores Cartões"
  description="Dúvidas sobre reviews ou quer sugerir um novo cartão de crédito para analisarmos? Envie uma mensagem para nossa equipe de finanças."
>

  <!-- Hero Header -->
  <section class="bg-purple-900 text-white py-16 text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="font-display font-extrabold text-3xl sm:text-4xl md:text-5xl leading-tight">
        Fale Conosco
      </h1>
      <p class="mt-4 text-sm sm:text-base text-purple-200 max-w-2xl mx-auto leading-relaxed">
        Tem dúvidas sobre qual cartão solicitar ou quer enviar uma sugestão de review? Nossa equipe de especialistas está pronta para ajudar.
      </p>
    </div>
  </section>

  <!-- Form and details split layout -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex flex-col lg:flex-row gap-12">
      
      <!-- Left Column: Interactive Contact Form -->
      <div class="w-full lg:w-2/3">
        <div class="bg-white rounded-3xl border border-purple-50 shadow-sm p-6 sm:p-10 relative overflow-hidden">
          
          <!-- Success message overlay (Hidden initially) -->
          <div id="success-overlay" class="hidden absolute inset-0 bg-white/95 backdrop-blur-sm z-10 flex flex-col items-center justify-center text-center p-8 transition-all animate-fade-in">
            <div class="w-16 h-16 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center text-3xl mb-4 shadow-md border border-emerald-200">
              ✓
            </div>
            <h3 class="font-display font-bold text-2xl text-slate-900">Mensagem Enviada!</h3>
            <p class="text-slate-600 text-sm sm:text-base max-w-md mt-2 leading-relaxed">
              Muito obrigado pelo contato. Nossa equipe de analistas financeiros irá analisar sua mensagem e responderá em até <strong>24 horas úteis</strong>.
            </p>
            <button id="reset-form-btn" class="mt-6 px-6 py-2.5 bg-purple-600 hover:bg-purple-700 text-white font-semibold rounded-xl text-sm transition-all shadow-md">
              Enviar Outra Mensagem
            </button>
          </div>

          <!-- The main Form -->
          <form id="contact-form" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              
              <!-- Name Input -->
              <div class="space-y-2">
                <label for="name" class="text-xs font-bold uppercase tracking-wider text-slate-500">Seu Nome</label>
                <input 
                  type="text" 
                  id="name" 
                  name="name" 
                  required 
                  placeholder="Ex: Pedro de Souza" 
                  class="w-full bg-slate-50 border border-slate-200 focus:bg-white rounded-xl px-4 py-3 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:border-purple-600 focus:ring-1 focus:ring-purple-600 transition-all"
                />
              </div>

              <!-- Email Input -->
              <div class="space-y-2">
                <label for="email" class="text-xs font-bold uppercase tracking-wider text-slate-500">Seu E-mail</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  required 
                  placeholder="Ex: pedro@email.com" 
                  class="w-full bg-slate-50 border border-slate-200 focus:bg-white rounded-xl px-4 py-3 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:border-purple-600 focus:ring-1 focus:ring-purple-600 transition-all"
                />
              </div>

            </div>

            <!-- Subject Selection -->
            <div class="space-y-2">
              <label for="subject" class="text-xs font-bold uppercase tracking-wider text-slate-500">Assunto</label>
              <select 
                id="subject" 
                name="subject" 
                required 
                class="w-full bg-slate-50 border border-slate-200 focus:bg-white rounded-xl px-4 py-3 text-sm text-slate-800 focus:outline-none focus:border-purple-600 focus:ring-1 focus:ring-purple-600 transition-all appearance-none"
              >
                <option value="" disabled selected>Selecione um assunto...</option>
                <option value="duvida-cartao">Dúvida sobre qual Cartão escolher</option>
                <option value="sugestao-review">Sugerir um Cartão para Análise</option>
                <option value="reportar-erro">Reportar erro em taxas/anuidade</option>
                <option value="parcerias">Parcerias e Negócios</option>
                <option value="outros">Outros Assuntos</option>
              </select>
            </div>

            <!-- Message Input -->
            <div class="space-y-2">
              <label for="message" class="text-xs font-bold uppercase tracking-wider text-slate-500">Sua Mensagem</label>
              <textarea 
                id="message" 
                name="message" 
                rows="5" 
                required 
                placeholder="Escreva detalhadamente sua dúvida ou sugestão para nossos analistas..." 
                class="w-full bg-slate-50 border border-slate-200 focus:bg-white rounded-xl px-4 py-3 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:border-purple-600 focus:ring-1 focus:ring-purple-600 transition-all resize-none"
              ></textarea>
            </div>

            <!-- Submit Button -->
            <button 
              type="submit" 
              class="w-full bg-purple-600 hover:bg-purple-700 text-white font-bold text-sm py-3.5 rounded-xl transition-all shadow-md hover:shadow-lg shadow-purple-600/10 flex items-center justify-center gap-2 cursor-pointer"
            >
              <span>Enviar Mensagem</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 stroke-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </button>

          </form>

        </div>
      </div>

      <!-- Right Column: Info Cards -->
      <div class="w-full lg:w-1/3 space-y-8">
        
        <!-- Direct Contact Info -->
        <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm space-y-6">
          <h3 class="font-display font-bold text-slate-900 border-l-4 border-purple-600 pl-3">Contatos Diretos</h3>
          
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="text-xl">✉️</span>
              <div>
                <h4 class="text-xs font-bold text-slate-800">E-mail de Suporte</h4>
                <p class="text-slate-500 text-xs sm:text-sm leading-relaxed select-all">contato@melhorescartoes.com.br</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-xl">📍</span>
              <div>
                <h4 class="text-xs font-bold text-slate-800">Sede Administrativa</h4>
                <p class="text-slate-500 text-xs sm:text-sm leading-relaxed">Av. Paulista, 1000 - Bela Vista, São Paulo - SP</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-xl">🕒</span>
              <div>
                <h4 class="text-xs font-bold text-slate-800">Horário de Atendimento</h4>
                <p class="text-slate-500 text-xs sm:text-sm leading-relaxed">Segunda a Sexta-feira: 09h às 18h</p>
              </div>
            </li>
          </ul>
        </div>

        <!-- Privacy Assurance -->
        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-6 text-slate-500 space-y-2">
          <span class="text-xl">🔒</span>
          <h4 class="text-xs font-bold text-slate-800 tracking-wide uppercase">Garantia de Privacidade</h4>
          <p class="text-[11px] leading-relaxed">
            Nunca compartilhamos seus dados com instituições financeiras ou bancos sem sua prévia autorização. Seu e-mail está seguro em nosso banco de dados em total conformidade com a LGPD.
          </p>
        </div>

      </div>

    </div>
  </section>

  <!-- Client-Side Form Logic for instant feedback -->
  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const overlay = document.getElementById('success-overlay');
    const resetBtn = document.getElementById('reset-form-btn');

    if (form && overlay && resetBtn) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        overlay.classList.remove('hidden');
        form.reset();
      });

      resetBtn.addEventListener('click', () => {
        overlay.classList.add('hidden');
      });
    }
  </script>

</Layout>
