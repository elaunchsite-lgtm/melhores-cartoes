---
import Layout from '../../layouts/Layout.astro';
import CreditCard from '../../components/CreditCard.astro';
import { posts, CATEGORIES } from '../../data/posts';

// Get filter query parameter if any
const { searchParams } = Astro.url;
const filterCategory = searchParams.get('categoria');

const filteredPosts = filterCategory
  ? posts.filter(post => post.category.toLowerCase() === filterCategory.toLowerCase())
  : posts;
---

<Layout 
  title="Blog de Cartões de Crédito - Reviews e Análises"
  description="Dicas financeiras, guias de acúmulo de milhas e cashback, e análises completas dos melhores cartões de crédito do Brasil."
>
  <!-- Hero Header -->
  <section class="bg-purple-900 text-white py-12 sm:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center sm:text-left">
      <h1 class="font-display font-extrabold text-3xl sm:text-4xl md:text-5xl leading-tight">
        Blog de <span class="text-purple-300">Cartões de Crédito</span>
      </h1>
      <p class="mt-3 text-sm sm:text-base text-purple-200 max-w-2xl leading-relaxed">
        Descubra as melhores práticas para escolher limites altos, isentar anuidade, e acumular cashback ou milhas aéreas de forma acelerada.
      </p>
    </div>
  </section>

  <!-- Filter Navigation bar -->
  <section class="bg-white border-b border-purple-50 sticky top-[80px] z-40 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex items-center gap-4 overflow-x-auto whitespace-nowrap pb-1 no-scrollbar">
        <span class="text-xs font-bold uppercase tracking-wider text-slate-400">Filtrar por:</span>
        
        <a 
          href="/blog" 
          class={`px-4 py-1.5 rounded-full text-xs font-bold transition-all border ${!filterCategory ? 'bg-purple-600 text-white border-purple-600' : 'bg-slate-50 text-slate-600 border-slate-200 hover:border-purple-200 hover:text-purple-600'}`}
        >
          Todos os Cartões
        </a>

        {CATEGORIES.map(cat => (
          <a 
            href={`/blog?categoria=${cat.id}`} 
            class={`px-4 py-1.5 rounded-full text-xs font-bold transition-all border ${filterCategory?.toLowerCase() === cat.id ? 'bg-purple-600 text-white border-purple-600' : 'bg-slate-50 text-slate-600 border-slate-200 hover:border-purple-200 hover:text-purple-600'}`}
          >
            {cat.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Main Content Layout (Grid post listing) -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col lg:flex-row gap-10">
      
      <!-- Left Column: Posts list -->
      <div class="w-full lg:w-2/3">
        {filteredPosts.length === 0 ? (
          <div class="text-center py-20 bg-white rounded-2xl border border-slate-100 p-8">
            <p class="text-slate-500 font-medium text-lg">Nenhum cartão encontrado nesta categoria.</p>
            <p class="text-slate-400 text-sm mt-1">Tente filtrar por outra categoria ou ver todos os cartões.</p>
            <a href="/blog" class="mt-6 inline-flex items-center justify-center px-6 py-2.5 bg-purple-600 hover:bg-purple-700 text-white font-semibold rounded-xl text-sm transition-all shadow-md">
              Ver Todos os Cartões
            </a>
          </div>
        ) : (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
            {filteredPosts.map(post => (
              <article class="bg-white rounded-2xl border border-slate-100 hover:border-purple-100 shadow-sm hover:shadow-md transition-all overflow-hidden flex flex-col justify-between group">
                
                <!-- Credit Card Visual Header -->
                <div class="py-8 bg-slate-50 flex justify-center items-center relative overflow-hidden border-b border-slate-100">
                  <div class="scale-95 drop-shadow-md group-hover:scale-100 transition-transform duration-300">
                    <CreditCard 
                      color={post.cardColor} 
                      brand={post.cardBrand} 
                      level={post.cardLevel} 
                      score={post.score} 
                      category={post.category} 
                      size="md"
                    />
                  </div>
                </div>

                <!-- Text metadata and info -->
                <div class="p-6 flex-grow flex flex-col justify-between">
                  <div class="space-y-3">
                    <div class="flex items-center gap-2 text-[11px] font-semibold">
                      <span class="text-purple-600 uppercase tracking-wider bg-purple-50 px-2 py-0.5 rounded">
                        {post.category}
                      </span>
                      <span class="text-slate-300">•</span>
                      <span class="text-slate-500">{post.readTime}</span>
                    </div>

                    <a href={`/blog/${post.slug}`}>
                      <h2 class="font-display font-extrabold text-lg text-slate-900 group-hover:text-purple-600 transition-colors line-clamp-2 leading-snug">
                        {post.title}
                      </h2>
                    </a>

                    <p class="text-slate-600 text-xs sm:text-sm line-clamp-3 leading-relaxed">
                      {post.shortDescription}
                    </p>
                  </div>

                  <!-- Item footer -->
                  <div class="flex items-center justify-between pt-5 mt-5 border-t border-slate-50">
                    <div class="flex items-center gap-2">
                      <div class="w-8 h-8 rounded-full bg-purple-50 text-purple-700 font-bold text-xs flex items-center justify-center border border-purple-100">
                        {post.author.split(' ').map(n => n[0]).join('')}
                      </div>
                      <div>
                        <p class="text-xs font-bold text-slate-900">{post.author}</p>
                        <p class="text-[9px] text-slate-400">{post.date}</p>
                      </div>
                    </div>

                    <a href={`/blog/${post.slug}`} class="w-8 h-8 rounded-full bg-purple-50 text-purple-600 flex items-center justify-center group-hover:bg-purple-600 group-hover:text-white transition-all shadow-sm" aria-label={`Read ${post.title}`}>
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                  </div>
                </div>

              </article>
            ))}
          </div>
        )}
      </div>

      <!-- Right Column: Sidebar (Widgets matching general site structure) -->
      <aside class="w-full lg:w-1/3 space-y-8">
        
        <!-- Newsletter Signup Box -->
        <div class="bg-gradient-to-tr from-purple-900 to-indigo-950 text-white rounded-2xl p-6 shadow-md shadow-purple-950/10">
          <h3 class="font-display font-bold text-xl mb-3">Alertas de Novos Cartões</h3>
          <p class="text-purple-200 text-xs leading-relaxed mb-6">
            Bancos digitais e corretoras lançam novos benefícios e promoções de isenção frequentemente. Inscreva seu e-mail e seja avisado imediatamente.
          </p>
          <form class="space-y-3" onsubmit="event.preventDefault(); alert('E-mail cadastrado com sucesso!');">
            <input type="email" placeholder="Seu e-mail principal" required class="w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-purple-300 focus:outline-none focus:border-white focus:ring-1 focus:ring-white" />
            <button type="submit" class="w-full bg-white text-purple-900 hover:bg-purple-100 font-bold text-sm rounded-xl py-3 transition-all shadow-md">
              Cadastrar Gratuitamente
            </button>
          </form>
        </div>

        <!-- Featured Tips widget -->
        <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
          <h3 class="font-display font-bold text-base text-slate-900 border-l-4 border-purple-600 pl-3 mb-4">Dicas Rápidas</h3>
          <ul class="space-y-4">
            <li class="flex gap-3">
              <span class="text-lg">💡</span>
              <div>
                <h4 class="text-xs font-bold text-slate-800">Cuidado com o score de crédito</h4>
                <p class="text-slate-500 text-[11px] leading-relaxed mt-0.5">Evite solicitar vários cartões ao mesmo tempo, pois isso reduz temporariamente sua pontuação nos birôs.</p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="text-lg">🛫</span>
              <div>
                <h4 class="text-xs font-bold text-slate-800">Isenção por Duo Gourmet</h4>
                <p class="text-slate-500 text-[11px] leading-relaxed mt-0.5">A assinatura anual garante o Inter Black com salas VIP sem precisar investir de início.</p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="text-lg">💰</span>
              <div>
                <h4 class="text-xs font-bold text-slate-800">Não pague anuidade atoa</h4>
                <p class="text-slate-500 text-[11px] leading-relaxed mt-0.5">Sempre ligue no chat ou central do banco antes de vencer a fatura se quiser negociar taxas.</p>
              </div>
            </li>
          </ul>
        </div>

      </aside>

    </div>
  </section>
</Layout>
