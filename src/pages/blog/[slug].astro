---
import Layout from '../../layouts/Layout.astro';
import CreditCard from '../../components/CreditCard.astro';
import { posts } from '../../data/posts';

export async function getStaticPaths() {
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

// Filter 3 related posts (excluding current one)
const relatedPosts = posts.filter(p => p.slug !== post.slug).slice(0, 3);
---

<Layout title={post.title} description={post.shortDescription}>
  
  <!-- Breadcrumbs -->
  <nav class="bg-white border-b border-purple-50 py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ol class="flex items-center gap-2 text-xs font-medium text-slate-500">
        <li><a href="/" class="hover:text-purple-600 transition-colors">Início</a></li>
        <li class="text-slate-300">/</li>
        <li><a href="/blog" class="hover:text-purple-600 transition-colors">Blog</a></li>
        <li class="text-slate-300">/</li>
        <li><a href={`/blog?categoria=${post.category.toLowerCase()}`} class="hover:text-purple-600 transition-colors">{post.category}</a></li>
        <li class="text-slate-300">/</li>
        <li class="text-slate-800 font-bold truncate max-w-[200px] sm:max-w-none">{post.title}</li>
      </ol>
    </div>
  </nav>

  <!-- Post Header Intro -->
  <header class="bg-gradient-to-b from-purple-50/40 via-transparent to-transparent py-10 sm:py-14">
    <div class="max-w-5xl mx-auto px-4 text-center">
      
      <!-- Category Badge & Meta -->
      <div class="flex items-center justify-center gap-3 text-xs font-bold uppercase tracking-wider mb-4">
        <span class="px-3 py-1.5 rounded-md bg-purple-100 text-purple-700">
          {post.category}
        </span>
        <span class="text-slate-300">•</span>
        <span class="text-slate-500">{post.readTime}</span>
        <span class="text-slate-300">•</span>
        <span class="text-slate-500">{post.date}</span>
      </div>

      <!-- Title -->
      <h1 class="font-display font-extrabold text-3xl sm:text-4xl md:text-5xl text-slate-950 tracking-tight leading-tight">
        {post.title}
      </h1>

      <!-- Short Intro description -->
      <p class="mt-4 text-base sm:text-lg text-slate-600 max-w-3xl mx-auto leading-relaxed">
        {post.shortDescription}
      </p>

      <!-- Author Line -->
      <div class="mt-6 flex items-center justify-center gap-3">
        <div class="w-10 h-10 rounded-full bg-purple-100 text-purple-700 font-bold flex items-center justify-center border border-purple-200">
          {post.author.split(' ').map(n => n[0]).join('')}
        </div>
        <div class="text-left">
          <p class="text-xs sm:text-sm font-bold text-slate-950">{post.author}</p>
          <p class="text-[10px] text-slate-500">{post.authorRole}</p>
        </div>
      </div>

    </div>
  </header>

  <!-- Visual Credit Card Representation (Centered premium banner) -->
  <section class="max-w-5xl mx-auto px-4 mb-12">
    <div class="bg-white rounded-3xl border border-purple-100 shadow-xl shadow-purple-900/5 p-8 flex flex-col md:flex-row justify-between items-center gap-8 relative overflow-hidden">
      <div class="absolute inset-0 bg-radial-gradient from-purple-50/50 to-transparent pointer-events-none"></div>
      
      <!-- Left side: Credit Card Graphic -->
      <div class="z-10 py-4 flex justify-center w-full md:w-auto">
        <div class="scale-105 drop-shadow-2xl">
          <CreditCard 
            color={post.cardColor} 
            brand={post.cardBrand} 
            level={post.cardLevel} 
            score={post.score} 
            category={post.category} 
            size="lg"
          />
        </div>
      </div>

      <!-- Right side: Quick rating and bullet parameters -->
      <div class="z-10 w-full md:w-1/2 space-y-4">
        <div class="flex items-center gap-4">
          <div class="bg-purple-600 text-white font-black text-3xl px-4 py-2 rounded-2xl shadow-md">
            {post.score.toFixed(1)}
          </div>
          <div>
            <span class="text-xs text-slate-400 font-bold uppercase tracking-wider">Nota do Especialista</span>
            <p class="text-sm font-bold text-slate-900">Excelente recomendação de escolha</p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4 pt-4 border-t border-slate-100">
          <div>
            <span class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Anuidade</span>
            <p class="text-xs sm:text-sm font-semibold text-slate-800 truncate" title={post.anuidade}>{post.anuidade}</p>
          </div>
          <div>
            <span class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Cashback</span>
            <p class="text-xs sm:text-sm font-semibold text-slate-800 truncate" title={post.cashback}>{post.cashback}</p>
          </div>
          <div>
            <span class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Milhas</span>
            <p class="text-xs sm:text-sm font-semibold text-slate-800 truncate" title={post.pontos}>{post.pontos}</p>
          </div>
          <div>
            <span class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Salas VIP</span>
            <p class="text-xs sm:text-sm font-semibold text-slate-800 truncate" title={post.loungeAccess}>{post.loungeAccess}</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Post Content Layout -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 mb-20">
    <div class="flex flex-col lg:flex-row gap-10">
      
      <!-- Left Column: Detailed Post Content -->
      <div class="w-full lg:w-2/3">
        <div class="bg-white rounded-2xl border border-slate-100 p-6 sm:p-10 shadow-sm space-y-8">
          
          <!-- Detailed Scorecard parameters container -->
          <div>
            <h3 class="font-display font-bold text-lg text-slate-900 border-l-4 border-purple-600 pl-3 mb-4">
              Ficha Técnica do Cartão
            </h3>
            <div class="bg-slate-50 rounded-xl divide-y divide-slate-100">
              <div class="p-4 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-1">
                <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Isenção de Anuidade</span>
                <span class="text-xs sm:text-sm font-semibold text-slate-800 text-left sm:text-right max-w-sm">{post.anuidade}</span>
              </div>
              <div class="p-4 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-1">
                <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Retorno em Cashback</span>
                <span class="text-xs sm:text-sm font-semibold text-slate-800 text-left sm:text-right max-w-sm">{post.cashback}</span>
              </div>
              <div class="p-4 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-1">
                <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Conversão de Pontos</span>
                <span class="text-xs sm:text-sm font-semibold text-slate-800 text-left sm:text-right max-w-sm">{post.pontos}</span>
              </div>
              <div class="p-4 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-1">
                <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Limite Estimado Médio</span>
                <span class="text-xs sm:text-sm font-semibold text-slate-800 text-left sm:text-right max-w-sm">{post.limiteEstimated || post.limiteEstimado}</span>
              </div>
              <div class="p-4 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-1">
                <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Acesso a Salas VIP</span>
                <span class="text-xs sm:text-sm font-semibold text-slate-800 text-left sm:text-right max-w-sm">{post.loungeAccess}</span>
              </div>
            </div>
          </div>

          <!-- Pros and Cons Side-by-Side (Extremely rich) -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            
            <!-- Pros Box -->
            <div class="bg-emerald-50/50 border border-emerald-100 p-6 rounded-xl space-y-3">
              <div class="flex items-center gap-2 text-emerald-800">
                <span class="text-lg">✓</span>
                <h4 class="font-bold text-sm tracking-wide uppercase">Destaques Positivos</h4>
              </div>
              <ul class="space-y-2 text-xs sm:text-sm text-slate-700">
                {post.pros.map(pro => (
                  <li class="flex items-start gap-2.5">
                    <span class="text-emerald-500 shrink-0 font-bold">✓</span>
                    <span>{pro}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Cons Box -->
            <div class="bg-rose-50/50 border border-rose-100 p-6 rounded-xl space-y-3">
              <div class="flex items-center gap-2 text-rose-800">
                <span class="text-lg">✗</span>
                <h4 class="font-bold text-sm tracking-wide uppercase">Pontos Negativos</h4>
              </div>
              <ul class="space-y-2 text-xs sm:text-sm text-slate-700">
                {post.cons.map(con => (
                  <li class="flex items-start gap-2.5">
                    <span class="text-rose-500 shrink-0 font-bold">✗</span>
                    <span>{con}</span>
                  </li>
                ))}
              </ul>
            </div>

          </div>

          <!-- Detailed Rich Content HTML rendered here -->
          <article class="prose max-w-none text-slate-600 text-sm sm:text-base leading-relaxed space-y-6">
            <div class="border-t border-slate-100 pt-6">
              <Fragment set:html={post.detailedContent} />
            </div>
          </article>

        </div>
      </div>

      <!-- Right Column: Sidebar (Widgets matching general site structure) -->
      <aside class="w-full lg:w-1/3 space-y-8">
        
        <!-- Summary Box -->
        <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm space-y-4">
          <h3 class="font-display font-bold text-slate-900 border-l-4 border-purple-600 pl-3">Recomendado Para</h3>
          <p class="text-slate-600 text-xs sm:text-sm leading-relaxed bg-purple-50/50 p-4 rounded-xl border border-purple-100">
            {post.recommendedFor}
          </p>
        </div>

        <!-- Related Posts Widget -->
        <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm space-y-4">
          <h3 class="font-display font-bold text-slate-900 border-l-4 border-purple-600 pl-3">Outros Reviews</h3>
          <div class="divide-y divide-slate-100">
            {relatedPosts.map(rel => (
              <a href={`/blog/${rel.slug}`} class="py-4 block group">
                <span class="text-[10px] font-bold uppercase tracking-wider text-purple-600 bg-purple-50 px-2 py-0.5 rounded">
                  {rel.category}
                </span>
                <h4 class="font-bold text-xs sm:text-sm text-slate-900 group-hover:text-purple-600 transition-colors mt-2 line-clamp-2">
                  {rel.title}
                </h4>
                <div class="flex items-center gap-2 mt-2 text-[10px] text-slate-400">
                  <span>Nota: {rel.score.toFixed(1)}</span>
                  <span>•</span>
                  <span>{rel.date}</span>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Score/Risk Disclaimer Warning -->
        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-6 text-slate-500">
          <span class="text-xl">⚠️</span>
          <h4 class="text-xs font-bold text-slate-800 mt-2">Sobre as Aprovações</h4>
          <p class="text-[11px] leading-relaxed mt-1">
            Recomendamos manter seu score no Serasa atualizado e o cadastro positivo ativo para aumentar drasticamente as chances de aprovação nestas variantes de alta renda. O Banco emissor tem critérios próprios que mudam sem aviso prévio.
          </p>
        </div>

      </aside>

    </div>
  </section>

</Layout>
